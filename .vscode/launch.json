{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Launch Qt App",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/VideoPlayer", // 替换为你的程序名
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    // 将 Qt 的库路径添加到程序运行时环境
                    "name": "DYLD_LIBRARY_PATH",
                    "value": "Users/mac/Qt/6.9.3/macos/lib:${env:DYLD_LIBRARY_PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "lldb" // macOS 默认调试器
        }
    ]
}